<!DOCTYPE html>
<html lang="en" class="no-js">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>

    <!-- SEO -->
    <meta name="description" content="<%= typeof metaDescription !== 'undefined' && metaDescription ? metaDescription : 'limbow — 3D artist & digital creator. Portfolio showcasing character art, environment design, and illustration. Open for commissions.' %>" />
    <meta name="author" content="limbow" />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:title" content="<%= title %>" />
    <meta property="og:description" content="<%= typeof metaDescription !== 'undefined' && metaDescription ? metaDescription : 'limbow — 3D artist & digital creator. Open for commissions.' %>" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="<%= typeof ogImage !== 'undefined' && ogImage ? ogImage : '/images/logo.png' %>" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="<%= title %>" />
    <meta name="twitter:description" content="<%= typeof metaDescription !== 'undefined' && metaDescription ? metaDescription : 'limbow — 3D artist & digital creator. Open for commissions.' %>" />
    <meta name="twitter:image" content="<%= typeof ogImage !== 'undefined' && ogImage ? ogImage : '/images/logo.png' %>" />

    <link rel="icon" href="/images/favicon.ico">
    
    <!-- Early theme initialization to prevent flash -->
    <script>
        (function() {
            const STORAGE_KEY = 'limbow-theme';
            let theme = localStorage.getItem(STORAGE_KEY);
            
            if (!theme) {
                if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
                    theme = 'dark';
                } else {
                    theme = 'light';
                }
            }
            
            document.documentElement.setAttribute('data-theme', theme);

            function syncToggleButton(currentTheme) {
                const button = document.getElementById('theme-toggle-btn');
                if (!button) return;
                button.classList.toggle('theme-toggle--toggled', currentTheme === 'dark');
            }
            
            window.toggleTheme = function() {
                const current = document.documentElement.getAttribute('data-theme');
                const newTheme = current === 'dark' ? 'light' : 'dark';
                document.documentElement.setAttribute('data-theme', newTheme);
                localStorage.setItem(STORAGE_KEY, newTheme);
                syncToggleButton(newTheme);
            };
            
            function attachHandler() {
                const btn = document.getElementById('theme-toggle-btn');
                if (btn) {
                    btn.onclick = window.toggleTheme;
                    syncToggleButton(document.documentElement.getAttribute('data-theme') || theme);
                } else {
                    setTimeout(attachHandler, 500);
                }
            }
            
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', attachHandler);
            } else {
                attachHandler();
            }
        })();
    </script>
    
    <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>" type="text/css" />

    <!-- Analytics — replace with your Plausible/Fathom domain or remove if not needed -->
    <!-- <script defer data-domain="yourdomain.com" src="https://plausible.io/js/script.js"></script> -->
