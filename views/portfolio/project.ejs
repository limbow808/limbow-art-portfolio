<%- include("header", {title: title}); %>

<body>
    <div class="wrapper">
        <%- include("nav"); %>
        <div class="main" role="main" id="main">
            <div class="content project-page">

                <a href="/" class="back-link">&larr; Back to Gallery</a>

                <!-- Title -->
                <h1 class="project-title"><%= project.title %></h1>

                <!-- Smart info panels — only rendered when data exists -->
                <div class="project-panels">

                    <%
                        // Collect detail items for the info strip
                        var infoItems = [];
                        if (project.title) infoItems.push({ label: 'Project', value: project.title });
                        if (project.category) infoItems.push({ label: 'Category', value: project.category });
                        if (project.workType) infoItems.push({ label: 'Type', value: project.workType });
                        if (project.date) infoItems.push({ label: 'Date', value: project.date });
                    %>
                    <% if (infoItems.length > 0) { %>
                        <div class="project-panel project-panel--info">
                            <% infoItems.forEach(function(item) { %>
                                <div class="project-panel-item">
                                    <span class="project-panel-label"><%= item.label %></span>
                                    <span class="project-panel-value"><%= item.value %></span>
                                </div>
                            <% }); %>
                        </div>
                    <% } %>

                    <% if (project.notes) { %>
                        <div class="project-panel project-panel--notes">
                            <span class="project-panel-label">Notes</span>
                            <p class="project-panel-text"><%= project.notes %></p>
                        </div>
                    <% } %>

                    <% 
                        var softwareList = project.software || project.tools || [];
                    %>
                    <% if (softwareList && softwareList.length > 0) { %>
                        <%
                            // Flatten: split any comma-separated entries into individual names
                            var allSoftware = [];
                            softwareList.forEach(function(t) {
                                t.split(',').forEach(function(s) {
                                    var trimmed = s.trim();
                                    if (trimmed) allSoftware.push(trimmed);
                                });
                            });
                        %>
                        <% if (allSoftware.length > 0) { %>
                            <div class="project-panel project-panel--tools">
                                <span class="project-panel-label">Software</span>
                                <div class="project-tools-list">
                                    <% allSoftware.forEach(function(sw) { %>
                                        <span class="project-tool-tag"><%= sw %></span>
                                    <% }); %>
                                </div>
                            </div>
                        <% } %>
                    <% } %>

                </div>

                <!-- Main image (always shown if no viewer/gallery folders exist) -->
                <% if (mainImagePath && (!viewerSections || viewerSections.length === 0) && (!galleryItems || galleryItems.length === 0)) { %>
                    <div class="project-viewer" id="projectViewer">
                        <img id="projectHeroImg" class="project-viewer-image" src="<%= mainImagePath %>?w=2000" alt="<%= project.title %>" />
                    </div>
                <% } %>

                <!-- Viewer sections — arrow-cycling through images in viewer/ folders -->
                <% if (viewerSections && viewerSections.length > 0) { %>
                    <% viewerSections.forEach(function(section, sIdx) { %>
                        <% if (viewerSections.length > 1) { %>
                            <h2 class="project-section-heading"><%= section.label %></h2>
                        <% } %>
                        <div class="project-viewer" id="projectViewer<%= sIdx %>">
                            <img class="project-viewer-image viewer-hero" src="<%= section.images[0].path %>?w=2000" alt="<%= project.title %>" />

                            <% if (section.images.length > 1) { %>
                                <button class="project-viewer-arrow project-viewer-arrow--left" onclick="cycleViewer(<%= sIdx %>, -1)" aria-label="Previous">&#8249;</button>
                                <button class="project-viewer-arrow project-viewer-arrow--right" onclick="cycleViewer(<%= sIdx %>, 1)" aria-label="Next">&#8250;</button>

                                <div class="project-viewer-thumbs">
                                    <% section.images.forEach(function(v, i) { %>
                                        <img class="project-viewer-thumb<%= i === 0 ? ' active' : '' %>"
                                             src="<%= v.path %>?w=200"
                                             alt="<%= v.name %>"
                                             data-section="<%= sIdx %>"
                                             data-index="<%= i %>"
                                             data-full="<%= v.path %>?w=2000"
                                             onclick="goToViewerImage(<%= sIdx %>, <%= i %>)" />
                                    <% }); %>
                                </div>
                            <% } %>
                        </div>
                    <% }); %>
                <% } %>

                <!-- Gallery — smart layout with optional notes from gallery.json -->
                <% if (galleryItems && galleryItems.length > 0) { %>
                    <% if (galleryLabel) { %>
                        <h2 class="project-section-heading"><%= galleryLabel %></h2>
                    <% } %>
                    <div class="project-gallery" id="projectGallery">
                        <% galleryItems.forEach(function(item) { %>
                            <% if (item.type === 'image') { %>
                                <div class="project-gallery-cell">
                                    <img class="project-gallery-img" src="<%= item.src %>?w=1400" alt="" loading="lazy" />
                                </div>
                            <% } else if (item.type === 'note') { %>
                                <div class="project-gallery-note">
                                    <p><%= item.text %></p>
                                </div>
                            <% } %>
                        <% }); %>
                    </div>
                <% } %>

                <!-- Workflow / process images -->
                <% if (workflowImages && workflowImages.length > 0) { %>
                    <h2 class="project-section-heading"><%= workflowLabel %></h2>
                    <div class="project-workflow">
                        <% workflowImages.forEach(function(img) { %>
                            <img class="project-workflow-image" src="<%= img %>?w=800" alt="" loading="lazy" />
                        <% }); %>
                    </div>
                <% } %>

            </div>
            <%- include("footer"); %>
        </div>
    </div>

    <script>
        // ---------- Multiple viewer sections ----------
        var viewers = document.querySelectorAll('[id^="projectViewer"]');
        var viewerState = [];
        viewers.forEach(function(v, i) {
            viewerState.push({ index: 0, el: v });
        });

        function goToViewerImage(sectionIdx, imgIdx) {
            var viewer = viewerState[sectionIdx];
            if (!viewer) return;
            viewer.index = imgIdx;
            var heroImg = viewer.el.querySelector('.viewer-hero');
            var thumbs = viewer.el.querySelectorAll('.project-viewer-thumb');
            var thumb = thumbs[imgIdx];
            if (heroImg && thumb && thumb.dataset.full) {
                heroImg.src = thumb.dataset.full;
            }
            thumbs.forEach(function(t) { t.classList.remove('active'); });
            if (thumb) thumb.classList.add('active');
        }

        function cycleViewer(sectionIdx, direction) {
            var viewer = viewerState[sectionIdx];
            if (!viewer) return;
            var thumbs = viewer.el.querySelectorAll('.project-viewer-thumb');
            var total = thumbs.length;
            if (!total) return;
            viewer.index = (viewer.index + direction + total) % total;
            goToViewerImage(sectionIdx, viewer.index);
        }

        // ---------- Gallery grid: classify cells by aspect ratio ----------
        (function() {
            var gallery = document.getElementById('projectGallery');
            if (!gallery) return;

            var imgs = gallery.querySelectorAll('.project-gallery-img');
            imgs.forEach(function(img) {
                function classify() {
                    var ratio = img.naturalWidth / img.naturalHeight;
                    var cell = img.closest('.project-gallery-cell');
                    if (!cell) return;
                    if (ratio >= 1.78) {
                        cell.classList.add('gallery-wide');
                    }
                }
                if (img.complete && img.naturalWidth) {
                    classify();
                } else {
                    img.addEventListener('load', classify);
                }
            });
        })();
    </script>
</body>

</html>
