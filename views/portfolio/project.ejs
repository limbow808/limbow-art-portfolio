<%- include("header", {title: title}); %>

<body>
    <div class="wrapper">
        <%- include("nav"); %>
        <div class="main" role="main" id="main">
            <div class="content project-page">

                <a href="/" class="back-link">&larr; Back to Gallery</a>

                <!-- Title -->
                <h1 class="project-title"><%= project.title %></h1>

                <!-- Smart info panels — only rendered when data exists -->
                <div class="project-panels">

                    <%
                        // Collect detail items for the info strip
                        var infoItems = [];
                        if (project.title) infoItems.push({ label: 'Project', value: project.title });
                        if (project.date) infoItems.push({ label: 'Date', value: project.date });
                        if (project.scope) infoItems.push({ label: 'Scope', value: project.scope });
                        if (project.category) infoItems.push({ label: 'Category', value: project.category });
                        if (project.workType) infoItems.push({ label: 'Type', value: project.workType });
                    %>
                    <% if (infoItems.length > 0) { %>
                        <div class="project-panel project-panel--info">
                            <% infoItems.forEach(function(item) { %>
                                <div class="project-panel-item">
                                    <span class="project-panel-label"><%= item.label %></span>
                                    <span class="project-panel-value"><%= item.value %></span>
                                </div>
                            <% }); %>
                        </div>
                    <% } %>

                    <% if (project.notes) { %>
                        <div class="project-panel project-panel--notes">
                            <span class="project-panel-label">Notes</span>
                            <p class="project-panel-text"><%= project.notes %></p>
                        </div>
                    <% } %>

                    <% if (project.tools && project.tools.length > 0) { %>
                        <%
                            // Flatten: split any comma-separated entries into individual tool names
                            var allTools = [];
                            project.tools.forEach(function(t) {
                                t.split(',').forEach(function(s) {
                                    var trimmed = s.trim();
                                    if (trimmed) allTools.push(trimmed);
                                });
                            });
                        %>
                        <% if (allTools.length > 0) { %>
                            <div class="project-panel project-panel--tools">
                                <span class="project-panel-label">Tools</span>
                                <div class="project-tools-list">
                                    <% allTools.forEach(function(tool) { %>
                                        <span class="project-tool-tag"><%= tool %></span>
                                    <% }); %>
                                </div>
                            </div>
                        <% } %>
                    <% } %>

                </div>

                <%
                    // Determine display mode: "viewer" (default), "gallery", or "both"
                    var displayMode = (project.displayMode || 'viewer').toLowerCase();
                    var showViewer  = (displayMode === 'viewer' || displayMode === 'both');
                    var showGallery = (displayMode === 'gallery' || displayMode === 'both');

                    // Collect all images for the gallery grid
                    var galleryImages = [];
                    if (showGallery && variants && variants.length > 0) {
                        galleryImages = variants.map(function(v) { return v.path; });
                    } else if (showGallery && mainImagePath) {
                        galleryImages = [mainImagePath];
                    }
                %>

                <!-- Image viewer with variant overlay -->
                <% if (showViewer && mainImagePath) { %>
                    <div class="project-viewer" id="projectViewer">
                        <img id="projectHeroImg" class="project-viewer-image" src="<%= mainImagePath %>?w=2000" alt="<%= project.title %>" />

                        <% if (variants && variants.length > 1) { %>
                            <button class="project-viewer-arrow project-viewer-arrow--left" onclick="cycleVariant(-1)" aria-label="Previous variant">&#8249;</button>
                            <button class="project-viewer-arrow project-viewer-arrow--right" onclick="cycleVariant(1)" aria-label="Next variant">&#8250;</button>

                            <div class="project-viewer-thumbs">
                                <% variants.forEach(function(v, i) { %>
                                    <img class="project-viewer-thumb<%= i === 0 ? ' active' : '' %>"
                                         src="<%= v.path %>?w=200"
                                         alt="<%= v.name %>"
                                         data-index="<%= i %>"
                                         data-full="<%= v.path %>?w=2000"
                                         onclick="goToVariant(<%= i %>)" />
                                <% }); %>
                            </div>
                        <% } %>
                    </div>
                <% } %>

                <!-- Gallery grid — smart layout based on aspect ratio -->
                <% if (showGallery && galleryImages.length > 0) { %>
                    <div class="project-gallery" id="projectGallery">
                        <% galleryImages.forEach(function(imgPath) { %>
                            <div class="project-gallery-cell">
                                <img class="project-gallery-img" src="<%= imgPath %>?w=1400" alt="" loading="lazy" />
                            </div>
                        <% }); %>
                    </div>
                <% } %>

                <!-- Extra images from project folder -->
                <% if (extraImages && extraImages.length > 0) { %>
                    <h2 class="project-section-heading">More</h2>
                    <div class="project-extra-images">
                        <% extraImages.forEach(function(img) { %>
                            <img class="project-extra-image" src="<%= img %>?w=800" alt="" loading="lazy" />
                        <% }); %>
                    </div>
                <% } %>

                <!-- Workflow / process images -->
                <% if (workflowImages && workflowImages.length > 0) { %>
                    <h2 class="project-section-heading">Process</h2>
                    <div class="project-workflow">
                        <% workflowImages.forEach(function(img) { %>
                            <img class="project-workflow-image" src="<%= img %>?w=800" alt="" loading="lazy" />
                        <% }); %>
                    </div>
                <% } %>

            </div>
            <%- include("footer"); %>
        </div>
    </div>

    <script>
        var currentVariantIndex = 0;
        var variantThumbs = document.querySelectorAll('.project-viewer-thumb');
        var heroImg = document.getElementById('projectHeroImg');

        function goToVariant(index) {
            if (!variantThumbs.length) return;
            currentVariantIndex = index;
            var thumb = variantThumbs[index];
            if (heroImg && thumb && thumb.dataset.full) {
                heroImg.src = thumb.dataset.full;
            }
            variantThumbs.forEach(function(t) { t.classList.remove('active'); });
            if (thumb) thumb.classList.add('active');
        }

        function cycleVariant(direction) {
            var total = variantThumbs.length;
            if (!total) return;
            currentVariantIndex = (currentVariantIndex + direction + total) % total;
            goToVariant(currentVariantIndex);
        }

        // ---------- Gallery grid: classify cells by aspect ratio ----------
        (function() {
            var gallery = document.getElementById('projectGallery');
            if (!gallery) return;

            var imgs = gallery.querySelectorAll('.project-gallery-img');
            imgs.forEach(function(img) {
                function classify() {
                    var ratio = img.naturalWidth / img.naturalHeight;
                    var cell = img.closest('.project-gallery-cell');
                    if (!cell) return;
                    // Wide: 16:9 or wider (ratio >= ~1.78)
                    if (ratio >= 1.78) {
                        cell.classList.add('gallery-wide');
                    }
                }
                if (img.complete && img.naturalWidth) {
                    classify();
                } else {
                    img.addEventListener('load', classify);
                }
            });
        })();
    </script>
</body>

</html>
