<%- include("header", {title: title}); %>

<body>
    <div class="wrapper">

        <%- include('nav'); %>

        <div class="main" role="main" id="main">
            <div class="content project-page">

                <!-- Hero-style logo banner -->
                <div class="info-hero">
                    <img src="/images/logo.png" alt="limbow" class="info-hero-img" />
                </div>

                <!-- Bio & info panels -->
                <div class="project-panels">
                    <div class="project-panel project-panel--notes">
                        <span class="project-panel-label">About</span>
                        <p class="project-panel-text">Berlin-based artist specialising in character design, environment art, and stylised illustration. Working across commissions, personal projects, and collaborative creative work — always exploring new ways to bring ideas to life in three dimensions.</p>
                        <p class="project-panel-text">With a background spanning concept art, digital sculpting, and real-time rendering, every project is approached with an eye for detail and a drive to push the craft further.</p>
                    </div>

                    <div class="project-panel project-panel--notes">
                        <span class="project-panel-label">Services</span>
                        <p class="project-panel-text">Commission Work — Open to freelance commissions for individuals & studios. Reach out via the contact page for rates and availability.</p>
                    </div>

                    <div class="project-panel project-panel--tools">
                        <span class="project-panel-label">Software</span>
                        <div class="project-tools-list">
                            <span class="project-tool-tag">Blender</span>
                            <span class="project-tool-tag">ZBrush</span>
                            <span class="project-tool-tag">Daz3D</span>
                            <span class="project-tool-tag">Substance Painter</span>
                            <span class="project-tool-tag">Marvelous Designer</span>
                            <span class="project-tool-tag">Photoshop</span>
                            <span class="project-tool-tag">Ableton Live</span>
                            <span class="project-tool-tag">FL Studio</span>
                        </div>
                    </div>
                </div>

            </div>
            <%- include('footer'); %>
        </div>
    </div>
</body>

</html>
