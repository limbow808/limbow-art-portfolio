<%- include("header", {title: title}); %>

<body>
    <div class="wrapper">

        <%- include('nav'); %>

        <div class="main" role="main" id="main">
            <div class="content project-page">

                <!-- Hero-style logo banner -->
                <div class="info-hero">
                    <img src="/images/logo.png" alt="limbow" class="info-hero-img" />
                </div>

                <!-- Bio & info panels -->
                <div class="project-panels">
                    <div class="project-panel project-panel--notes">
                        <span class="project-panel-label">About</span>
                        <p class="project-panel-text">Swedish-based 3D artist specialising in character design, environment art, and stylised illustration. Working across commissions, personal projects, and collaborative creative work — always exploring new ways to bring ideas to life in three dimensions.</p>
                        <p class="project-panel-text">With a background spanning concept art, digital sculpting, and real-time rendering, every project is approached with an eye for detail and a drive to push the craft further.</p>
                    </div>

                    <div class="project-panel project-panel--notes">
                        <span class="project-panel-label">Services</span>
                        <p class="project-panel-text">Character Design &amp; Modelling — Original characters, fan art, VTuber models, and stylised portraits brought to life in 3D.</p>
                        <p class="project-panel-text">Environment &amp; Scene Art — Atmospheric environments and compositions for illustration, games, or personal projects.</p>
                        <p class="project-panel-text">Commission Work — Open to freelance commissions for individuals, studios, and content creators. Reach out via the contact page for rates and availability.</p>
                    </div>

                    <div class="project-panel project-panel--notes">
                        <span class="project-panel-label">Software &amp; Tools</span>
                        <p class="project-panel-text">Blender · ZBrush · Daz3D · Substance Painter · Marvelous Designer · Photoshop · Clip Studio Paint</p>
                    </div>
                </div>

            </div>
            <%- include('footer'); %>
        </div>
    </div>
</body>

</html>
