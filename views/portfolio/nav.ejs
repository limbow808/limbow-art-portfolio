<div class="header" id="header" role="banner">
    <div class="nav" id="outer-nav">
        <div id="nav" role="navigation">
            <ul class="nav-list">
                <li class="<%= (currentURL === '/') ? 'active' : '' %>">
                    <a class="nav-item" href="/">Overview</a>
                </li>
                <li class="<%= (currentURL === '/about') ? 'active' : '' %>">
                    <a class="nav-item" href="/about">About</a>
                </li>
                <li class="<%= (currentURL === '/contact') ? 'active' : '' %>">
                    <a class="nav-item" href="/contact">Contact</a>
                </li>
            </ul>
        </div>

        <!-- Commission banner — remove or comment out this block to hide -->
        <div class="commission-banner">
            <span class="commission-banner-dot"></span>
            <a href="/contact">Open for commissions</a>
        </div>
        <!-- End commission banner -->

        <button
            class="theme-toggle"
            type="button"
            id="theme-toggle-btn"
            title="Toggle theme"
            aria-label="Toggle theme"
        >
            <div class="theme-toggle__icon">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    aria-hidden="true"
                    width="1em"
                    height="1em"
                    class="theme-toggle__simple"
                    fill="currentColor"
                    viewBox="0 0 32 32"
                >
                    <clipPath id="theme-toggle__simple__cutout">
                        <path d="M0-5h55v37h-55zm32 12a1 1 0 0025 0 1 1 0 00-25 0" />
                    </clipPath>
                    <g clip-path="url(#theme-toggle__simple__cutout)">
                        <circle cx="16" cy="16" r="15" />
                    </g>
                </svg>
            </div>
        </button>
    </div>
</div>
