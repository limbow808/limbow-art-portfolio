{
  "name": "website_limbow",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build:css": "npx sass --load-path=node_modules public/scss/style.scss public/css/style.css",
    "build:images": "node scripts/build-image-meta.js",
    "watch:css": "sass --watch public/scss/style.scss:public/css/style.css",
    "build:legacy": "npm run build:css && npm run build:images",
    "client:install": "cd client && npm install --include=dev",
    "client:dev": "cd client && npm run dev",
    "client:build": "cd client && npm run build",
    "dev": "node index.js",
    "build": "npm run build:legacy && npm run client:install && npm run client:build",
    "start": "node index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lvndquist/website_limbow.git"
  },
  "author": "lvndquist",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/lvndquist/website_limbow/issues"
  },
  "homepage": "https://github.com/lvndquist/website_limbow#readme",
  "dependencies": {
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "normalize.css": "^8.0.1",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "sass": "^1.86.0"
  }
}
